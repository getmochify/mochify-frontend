PUBLIC_API_URL=http://localhost
PUBLIC_SUPABASE_URL=https://something.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Supabase service role — never expose to the client. Used by webhook handler.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-dashboard

# Polar.sh — from your Polar organization settings.
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_PRODUCT_ID_LITE_MONTHLY=your-lite-monthly-product-id
POLAR_PRODUCT_ID_LITE_YEARLY=your-lite-yearly-product-id
POLAR_PRODUCT_ID_PRO_MONTHLY=your-pro-monthly-product-id
POLAR_PRODUCT_ID_PRO_YEARLY=your-pro-yearly-product-id

# Cloudflare Worker — used to reseed DO token bucket on plan changes.
CF_WORKER_URL=https://mochify-tokens.<subdomain>.workers.dev
CF_WORKER_TOKEN=your-internal-token
