PUBLIC_API_URL=http://localhost
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_WORKER_URL=https://

# Polar.sh — from your Polar organization settings.
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_PRODUCT_ID_SELLER_MONTHLY=your-seller-monthly-product-id
POLAR_PRODUCT_ID_SELLER_YEARLY=your-seller-yearly-product-id
POLAR_PRODUCT_ID_PRO_MONTHLY=your-pro-monthly-product-id
POLAR_PRODUCT_ID_PRO_YEARLY=your-pro-yearly-product-id

# Cloudflare Worker — used to reseed DO token bucket on plan changes.
CF_WORKER_URL=https://
CF_WORKER_TOKEN=your-internal-token

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
# Pepper prepended to passwords before PBKDF2 hashing. Generate with: openssl rand -base64 32
# WARNING: losing this value makes all passwords unrecoverable — back it up securely.
PBKDF2_PEPPER=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
RESEND_API_KEY=re_your_key_from_resend_dashboard

# Mistral
MISTRAL_API_KEY=your-mistral-key