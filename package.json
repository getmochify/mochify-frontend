{
  "name": "mochify-frontend",
  "version": "1.0.0",
  "packageManager": "bun@1.3.14",
  "description": "Open-source SvelteKit frontend for Mochify. High-performance, privacy-first image processing with zero-data retention.",
  "keywords": [
    "sveltekit",
    "privacy",
    "image-processing",
    "security",
    "stateless",
    "cpp-backend"
  ],
  "license": "MIT",
  "author": "Taylor Liesnham <hello@mochify.app> (https://mochify.app)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getmochify/mochify-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/getmochify/mochify-frontend/issues"
  },
  "homepage": "https://mochify.app",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "patch-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.5",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.4",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "dependencies": {
    "@fontsource/nunito": "^5.3.0",
    "@fontsource/outfit": "^5.3.0",
    "@jsquash/jxl": "^1.3.0",
    "@polar-sh/sveltekit": "^0.7.6",
    "better-auth": "1.5.6",
    "fflate": "^0.8.3",
    "kysely": "^0.28.17",
    "kysely-d1": "^0.4.0",
    "mediabunny": "^1.51.0",
    "posthog-js": "^1.407.2",
    "posthog-node": "^5.46.1",
    "resend": "^6.18.0"
  }
}
